OPENROUTER_API_KEY=sk-or-...

# Optional: override the default model (default: google/gemini-3-flash-preview)
# CHAT_MODEL=google/gemini-3-flash-preview

# Rate limiting (Upstash Redis) — create free DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# Lead notifications (Resend) — create free account at https://resend.com
RESEND_API_KEY=re_...
LEAD_NOTIFICATION_EMAIL=info@shorelinedentalchicago.com
RESEND_FROM_EMAIL=Lab Sync <notifications@labsync.space>

# Leads API access key — any random string, passed as Authorization: Bearer <key> to GET /api/leads
LEADS_API_KEY=change-me-to-a-random-string
